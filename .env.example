# คัดลอกเป็น .env — ห้าม commit .env จริง
NODE_ENV=development
PORT=3000

# อย่างใดอย่างหนึ่ง (production บังคับ)
DATABASE_URL=mongodb://127.0.0.1:27017/bearthai
# MONGODB_URI=

# production: อย่างน้อย 32 ตัวอักษร
JWT_SECRET=change-me-to-a-secret-at-least-32-chars-long
JWT_EXPIRES_IN=7d

# URL ของแอป React (Vite) สำหรับลิงก์ยืนยันอีเมล — ไม่ใช่พอร์ต API; ไม่ต้องใส่ slash ท้าย
FRONTEND_URL=http://localhost:5173
# production: คั่นหลาย origin ด้วย comma
# ALLOWED_ORIGINS=https://app.example.com,https://staging.example.com

# CORS เข้ม: ตั้ง ALLOWED_ORIGINS แล้วใช้ STRICT_CORS=true
# STRICT_CORS=false
# CORS_ALLOW_VERCEL_PREVIEWS=false

# หลัง reverse proxy (nginx, load balancer)
# TRUST_PROXY=true

# Optional — AI / TTS
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=

# Email (ถ้าใช้)
# FRONTEND_URL ใช้ลิงก์ verify อีเมลด้วย

# Rate limit เฉพาะ auth (login/register + verify-email) — ดู middleware/authRateLimit.js
# AUTH_RATE_LIMIT_WINDOW_MS=900000
# AUTH_RATE_LIMIT_MAX=40
# AUTH_VERIFY_RATE_LIMIT_WINDOW_MS=3600000
# Bypass Email Verification (ตั้งเป็น true เฉพาะช่วงทดสอบที่ยังไม่ได้ตั้งค่า Email SMTP)
# BYPASS_EMAIL_VERIFY=false
